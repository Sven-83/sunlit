{
  "name": "iobroker.bk215",
  "version": "0.0.1",
  "description": "Local-first ioBroker adapter for Sunlit / SunEnergyXT BK215 battery storage with PI-based zero-feed-in control",
  "author": {
    "name": "Sven-83",
    "email": "svmorgen@gmx.de"
  },
  "homepage": "https://github.com/Sven-83/sunlit",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "BK215",
    "Sunlit",
    "SunEnergyXT",
    "Balkonkraftwerk",
    "Speicher",
    "Nulleinspeisung",
    "zero-feed-in",
    "PI-controller",
    "energy",
    "smarthome"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Sven-83/sunlit.git"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2",
    "bonjour-service": "^1.3.0"
  },
  "devDependencies": {
    "@iobroker/eslint-config": "^2.2.0",
    "@iobroker/testing": "^5.2.2",
    "@iobroker/types": "^7.0.0",
    "@types/chai": "^4.3.20",
    "@types/chai-as-promised": "^7.1.8",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/proxyquire": "^1.3.31",
    "@types/sinon": "^17.0.4",
    "@types/sinon-chai": "^3.2.12",
    "chai": "^4.5.0",
    "chai-as-promised": "^8.0.2",
    "globals": "^16.3.0",
    "mocha": "^11.7.5",
    "proxyquire": "^2.1.3",
    "rimraf": "^6.1.3",
    "sinon": "^18.0.1",
    "sinon-chai": "^3.7.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "main": "build/main.js",
  "files": [
    "admin/",
    "build/",
    "io-package.json",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "prebuild": "rimraf build",
    "build": "tsc -p tsconfig.build.json",
    "watch": "tsc -p tsconfig.build.json --watch",
    "test:unit": "mocha --config test/mocharc.custom.json 'test/unit/**/*.test.ts'",
    "test:package": "mocha --config test/mocharc.custom.json test/package.ts --exit",
    "test:integration": "mocha --config test/mocharc.custom.json test/integration.ts --exit",
    "test": "npm run test:unit && npm run test:package",
    "check": "tsc --noEmit -p tsconfig.check.json",
    "lint": "eslint -c eslint.config.mjs .",
    "translate": "translate-adapter",
    "release": "release-script",
    "release-patch": "release-script patch --yes",
    "release-minor": "release-script minor --yes",
    "release-major": "release-script major --yes"
  },
  "bugs": {
    "url": "https://github.com/Sven-83/sunlit/issues"
  },
  "readmeFilename": "README.md"
}