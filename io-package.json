        "name": "Battery storage"
      },
      "native": {}
    },
    {
      "_id": "battery.soc",
      "type": "state",
      "common": {
        "role": "value.battery",
        "name": "Overall state of charge",
        "type": "number",
        "unit": "%",
        "min": 0,
        "max": 100,
        "read": true,
        "write": false,
        "def": 0
      },
      "native": {}
    },
    {
      "_id": "battery.chargingPower",
      "type": "state",
