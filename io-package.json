    "authors": [
      "Sven-83 <svmorgen@gmx.de>"
    ],
    "keywords": [
      "BK215",
      "Sunlit",
      "SunEnergyXT",
      "Balkonkraftwerk",
      "Nulleinspeisung",
      "energy"
    ],
    "licenseInformation": {
      "type": "free",
      "license": "MIT"
    },
    "platform": "Javascript/Node.js",
    "main": "build/main.js",
    "icon": "bk215.png",
    "enabled": true,
    "extIcon": "https://raw.githubusercontent.com/Sven-83/sunlit/main/admin/bk215.png",
    "readme": "https://github.com/Sven-83/sunlit/blob/main/README.md",
    "loglevel": "info",
    "mode": "daemon",
    "type": "energy",
    "compact": true,
    "materialize": true,
    "connectionType": "local",
    "dataSource": "push",
    "adminUI": {
      "config": "json"
    },
    "dependencies": [
      {
        "js-controller": ">=5.0.19"
      }
    ],
    "globalDependencies": [
      {
        "admin": ">=6.13.16"
      }
    ],
    "tier": 2,
    "supportedMessages": {
      "custom": false,
      "deviceManager": false
    },
    "encryptedNative": [
      "cloudApiToken"
    ],
    "protectedNative": [
      "cloudApiToken"
    ]
  },
  "native": {
    "bk215Host": "192.168.178.24",
    "bk215Port": 8000,
    "bk215Serial": "dcbdccc00361",
    "bk215ConnectTimeoutMs": 5000,
    "bk215ResponseTimeoutMs": 2000,
    "bk215IdleTimeoutMs": 60000,
    "enableMdnsDiscovery": true,
    "gridStatePath": "0_userdata.0.shelly3em.total_act_power",
    "gridStaleTimeoutS": 15,
    "controllerEnabled": false,
    "controllerIntervalMs": 4000,
    "controllerKp": 0.7,
    "controllerKi": 0.05,
    "controllerDeadbandW": 30,
    "controllerTargetGridW": 0,
    "inverterMaxPowerW": 800,
    "socMin": 20,
    "socMax": 100,
    "socSafetyBuffer": 3,
    "enableApsInverter": true,
    "apsInverterHost": "192.168.178.189",
    "cloudApiToken": "",
    "logLevel": "info"
  },
  "objects": [],
  "instanceObjects": [
    {
      "_id": "info",
      "type": "channel",
      "common": {
        "name": "Information"
      },
      "native": {}
    },
    {
      "_id": "info.connection",
      "type": "state",
      "common": {
        "role": "indicator.connected",
        "name": "Connection to BK215 established",
        "type": "boolean",
        "read": true,
        "write": false,
        "def": false
      },
      "native": {}
    },
    {
      "_id": "info.lastSync",
      "type": "state",
      "common": {
        "role": "value.time",
        "name": "Last data sync from BK215",
        "type": "number",
        "read": true,
        "write": false,
        "def": 0
      },
      "native": {}
    },
    {
      "_id": "info.firmwareVersion",
      "type": "state",
      "common": {
        "role": "info.firmware",
        "name": "BK215 firmware version",
